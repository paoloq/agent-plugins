{
  "item": "plugins/task",
  "triggers": {
    "must_match_any": [
      "draft spec",
      "write a spec",
      "draft a spec",
      "/draft-spec",
      "produce a SPEC",
      "produce a spec document",
      "write a SPEC.md",
      "council",
      "deliberate",
      "plan with codex",
      "second opinion on the plan"
    ],
    "positive": [
      "draft a spec for adding rate limiting to the public API",
      "write a spec for the new onboarding flow",
      "can you produce a SPEC document for the migration from Postgres 14 to 16?",
      "/draft-spec refactor the auth middleware to use JWTs",
      "write a SPEC.md covering the dark-mode rollout",
      "let's run a council on the auth rewrite plan",
      "deliberate with codex before we commit to the migration approach",
      "i want to plan with codex on the queue refactor",
      "get a second opinion on the plan for the rate limiter"
    ],
    "negative": [
      "implement rate limiting in the API gateway",
      "review this pull request and flag issues",
      "summarize the engineering all-hands notes",
      "write a prompt that drafts release notes",
      "what does the OpenAI guide say about reasoning effort?",
      "audit this repo for agentic readiness",
      "open a pr for the queue refactor",
      "summarize the migration doc in two paragraphs"
    ]
  },
  "output": [
    {
      "id": "claude-plugin-manifest-present",
      "kind": "golden",
      "fixture": "../.claude-plugin/plugin.json",
      "must_contain": ["\"name\": \"task\""]
    },
    {
      "id": "draft-spec-skill-frontmatter",
      "kind": "golden",
      "fixture": "../skills/draft-spec/SKILL.md",
      "frontmatter_required_keys": ["name", "description"],
      "must_contain": [
        "disable-model-invocation: true",
        "ExitPlanMode",
        "./.specs/<slug>.md"
      ]
    },
    {
      "id": "draft-spec-skill-five-section-template",
      "kind": "golden",
      "fixture": "../skills/draft-spec/SKILL.md",
      "must_contain": [
        "## 1. Objective",
        "## 2. Context",
        "## 3. Constraints",
        "## 4. Success criteria & verification",
        "## 5. Stop rules"
      ]
    },
    {
      "id": "draft-spec-skill-token-discipline",
      "kind": "golden",
      "fixture": "../skills/draft-spec/SKILL.md",
      "must_contain": [
        "Token discipline",
        "No preamble",
        "Recon is silent"
      ]
    },
    {
      "id": "draft-spec-skill-uses-ask-user-question",
      "kind": "golden",
      "fixture": "../skills/draft-spec/SKILL.md",
      "must_contain": ["AskUserQuestion"]
    },
    {
      "id": "settings-allows-specs-dir",
      "kind": "golden",
      "fixture": "../.claude-plugin/settings.json",
      "must_contain": [
        "Edit(./.specs/**)",
        "Write(./.specs/**)",
        "showClearContextOnPlanAccept"
      ]
    },
    {
      "id": "no-implementation-during-interview",
      "kind": "golden",
      "fixture": "../skills/draft-spec/SKILL.md",
      "must_not_contain": [
        "Do implement during the interview"
      ],
      "regex_must_not_match": "(?i)implement (now|first) and"
    },
    {
      "id": "plan-council-skill-frontmatter",
      "kind": "golden",
      "fixture": "../skills/plan-council/SKILL.md",
      "frontmatter_required_keys": ["name", "description"],
      "must_contain": ["disable-model-invocation: true"]
    },
    {
      "id": "plan-council-roles-and-veto",
      "kind": "golden",
      "fixture": "../skills/plan-council/SKILL.md",
      "must_contain": ["Plan Council", "Codex", "veto power"]
    },
    {
      "id": "plan-council-enters-plan-mode",
      "kind": "golden",
      "fixture": "../skills/plan-council/SKILL.md",
      "must_contain": ["EnterPlanMode"]
    }
  ]
}
